@page
@model PMS.Web.Pages.Portal.DashboardModel
@{
    ViewData["Title"] = "Dashboard - Aranya Helpline";
    Layout = "_Layout";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <!-- Welcome Banner -->
        <div class="card mb-4" style="border:none; background: linear-gradient(135deg, #1B4332, #2D6A4F); border-radius:12px;">
            <div class="card-body p-4 text-white">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:2.5rem; background:rgba(255,255,255,0.15); border-radius:50%; width:60px; height:60px; display:flex; align-items:center; justify-content:center;">
                        👤
                    </div>
                    <div>
                        <h5 class="mb-1" style="font-family:'Noto Serif',serif; font-weight:700;">
                            Welcome, @Model.UserName!
                        </h5>
                        <div style="color:rgba(255,255,255,0.75); font-size:0.875rem;">
                            <i class="bi bi-phone me-1"></i>@Model.MobileNumber
                        </div>
                    </div>
                    <div class="ms-auto text-end">
                        <div style="font-size:1.8rem; font-weight:700;">@Model.TotalComplaints</div>
                        <div style="font-size:0.75rem; color:rgba(255,255,255,0.7);">Total Complaints</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Cards -->
        <div class="row g-3 mb-4">
            <div class="col-6">
                <a href="/Portal/MyComplaints" class="text-decoration-none">
                    <div class="card h-100 text-center p-4" style="border-radius:12px; border:2px solid #dee2e6; cursor:pointer; transition:all 0.2s;"
                         onmouseover="this.style.borderColor='#52B788'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 16px rgba(27,67,50,0.12)'"
                         onmouseout="this.style.borderColor='#dee2e6'; this.style.transform=''; this.style.boxShadow=''">
                        <div style="font-size:2.5rem; margin-bottom:12px;">📋</div>
                        <div style="font-weight:700; color:#1B4332; font-size:1rem;">My Complaints</div>
                        <div style="color:#6c757d; font-size:0.8rem; margin-top:4px;">View & track all your complaints</div>
                        <div class="mt-3">
                            <span style="background:#d8f3dc; color:#1B4332; border-radius:20px; padding:4px 14px; font-size:0.8rem; font-weight:600;">
                                @Model.TotalComplaints submitted
                            </span>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-6">
                <a href="/Portal/SubmitComplaint" class="text-decoration-none">
                    <div class="card h-100 text-center p-4" style="border-radius:12px; border:2px solid #dee2e6; cursor:pointer; transition:all 0.2s;"
                         onmouseover="this.style.borderColor='#52B788'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 16px rgba(27,67,50,0.12)'"
                         onmouseout="this.style.borderColor='#dee2e6'; this.style.transform=''; this.style.boxShadow=''">
                        <div style="font-size:2.5rem; margin-bottom:12px;">✍️</div>
                        <div style="font-weight:700; color:#1B4332; font-size:1rem;">New Complaint</div>
                        <div style="color:#6c757d; font-size:0.8rem; margin-top:4px;">Submit a new complaint</div>
                        <div class="mt-3">
                            <span style="background: linear-gradient(135deg,#1B4332,#2D6A4F); color:white; border-radius:20px; padding:4px 14px; font-size:0.8rem; font-weight:600;">
                                Create New
                            </span>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <!-- Recent Complaints -->
        @if (Model.RecentComplaints.Any())
        {
            <div class="card" style="border-radius:12px;">
                <div class="card-header-forest d-flex justify-content-between align-items-center">
                    <h5 style="font-family:'Noto Serif',serif;"><i class="bi bi-clock-history me-2"></i>Recent Complaints</h5>
                    <a href="/Portal/MyComplaints" class="text-warning text-decoration-none" style="font-size:0.85rem;">
                        View All <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    @foreach (var petition in Model.RecentComplaints)
                    {
                        <a href="/Portal/TrackComplaint?id=@petition.PetitionApplicationId"
                           class="text-decoration-none">
                            <div class="d-flex align-items-center gap-3 p-3"
                                 style="border-bottom:1px solid #f0f0f0; transition:background 0.2s;"
                                 onmouseover="this.style.background='#f8faf8'"
                                 onmouseout="this.style.background=''">
                                <div style="width:42px; height:42px; background:#d8f3dc; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0;">
                                    📄
                                </div>
                                <div class="flex-grow-1">
                                    <div style="font-weight:600; color:#1B4332; font-size:0.875rem;">
                                        @petition.PetitionApplicationId
                                    </div>
                                    <div style="color:#6c757d; font-size:0.78rem; margin-top:2px;">
                                        @petition.ComplaintCategory?.Name — @petition.SubmittedAt.ToString("dd MMM yyyy")
                                    </div>
                                </div>
                                <div>
                                    @{
                                        var (badgeColor, badgeText) = petition.Status switch
                                        {
                                            PMS.Web.Models.Enums.PetitionStatus.Submitted           => ("#fff3cd", "#856404"),
                                            PMS.Web.Models.Enums.PetitionStatus.UnderScrutiny       => ("#cfe2ff", "#084298"),
                                            PMS.Web.Models.Enums.PetitionStatus.Assigned            => ("#d1ecf1", "#0c5460"),
                                            PMS.Web.Models.Enums.PetitionStatus.InProgress          => ("#d4edda", "#155724"),
                                            PMS.Web.Models.Enums.PetitionStatus.Closed              => ("#d8f3dc", "#1B4332"),
                                            PMS.Web.Models.Enums.PetitionStatus.Dropped             => ("#f8d7da", "#721c24"),
                                            _ => ("#e2e3e5", "#383d41")
                                        };
                                        var statusLabel = petition.Status switch
                                        {
                                            PMS.Web.Models.Enums.PetitionStatus.Submitted           => "Submitted",
                                            PMS.Web.Models.Enums.PetitionStatus.UnderScrutiny       => "Under Review",
                                            PMS.Web.Models.Enums.PetitionStatus.RecommendedForAction=> "Forwarded",
                                            PMS.Web.Models.Enums.PetitionStatus.Assigned            => "Assigned",
                                            PMS.Web.Models.Enums.PetitionStatus.InProgress          => "In Progress",
                                            PMS.Web.Models.Enums.PetitionStatus.SubmittedForClosure => "Pending Closure",
                                            PMS.Web.Models.Enums.PetitionStatus.Closed              => "Closed",
                                            PMS.Web.Models.Enums.PetitionStatus.Dropped             => "Dropped",
                                            _ => petition.Status.ToString()
                                        };
                                    }
                                    <span style="background:@badgeColor; color:@badgeText; border-radius:20px; padding:4px 10px; font-size:0.75rem; font-weight:600; white-space:nowrap;">
                                        @statusLabel
                                    </span>
                                </div>
                                <i class="bi bi-chevron-right" style="color:#adb5bd;"></i>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

    </div>
</div>
