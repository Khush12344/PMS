@page
@model PMS.Web.Pages.OfficeAssistant.DashboardModel
@{ ViewData["Title"] = "Office Assistant Dashboard"; }

<style>
    .page-header { background:linear-gradient(135deg,#1a5c2a 0%,#2d8a45 100%); color:white; padding:24px 32px; border-radius:10px; margin-bottom:28px; }
    .stat-card { background:#fff; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,.07); padding:20px 24px; border-left:4px solid #e5e7eb; }
    .stat-card.c1 { border-left-color:#f59e0b; }
    .stat-card.c2 { border-left-color:#3b82f6; }
    .stat-card.c3 { border-left-color:#10b981; }
    .stat-card.c4 { border-left-color:#ef4444; }
    .stat-card.c5 { border-left-color:#d97706; }
    .stat-number { font-size:2rem; font-weight:700; color:#111827; }
    .stat-label  { font-size:.82rem; color:#6b7280; margin-top:2px; }

    .tab-btn { padding:7px 18px; border-radius:6px; border:1px solid #e5e7eb; background:#f9fafb; color:#374151; font-size:.84rem; font-weight:500; cursor:pointer; transition:all .15s; }
    .tab-btn.active,.tab-btn:hover { background:#1a5c2a; color:white; border-color:#1a5c2a; }

    .petition-row { background:#fff; border-radius:8px; box-shadow:0 1px 4px rgba(0,0,0,.06); padding:15px 20px; margin-bottom:10px; border-left:3px solid #e5e7eb; transition:box-shadow .15s; }
    .petition-row:hover { box-shadow:0 3px 12px rgba(0,0,0,.1); }
    .row-new      { border-left-color:#f59e0b; }
    .row-scrutiny { border-left-color:#3b82f6; }
    .row-forwarded{ border-left-color:#10b981; }
    .row-dropped  { border-left-color:#f59e0b; }
    .row-droprec  { border-left-color:#ef4444; }

    .pid  { font-family:monospace; font-size:.78rem; color:#6b7280; }
    .pcat { font-weight:600; font-size:.93rem; color:#111827; }
    .pdesc { font-size:.81rem; color:#6b7280; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:380px; }
    .pdate { font-size:.75rem; color:#9ca3af; }

    .bs { display:inline-block; padding:3px 10px; border-radius:20px; font-size:.73rem; font-weight:600; white-space:nowrap; }
    .bs-new      { background:#fef3c7; color:#92400e; }
    .bs-scrutiny { background:#dbeafe; color:#1d4ed8; }
    .bs-fwdact   { background:#d1fae5; color:#065f46; }
    .bs-fwddrop  { background:#fee2e2; color:#991b1b; }
    .bs-oadrop   { background:#fef3c7; color:#b45309; }

    .btn-act { font-size:.78rem; padding:4px 12px; border-radius:5px; border:none; font-weight:500; }
    .empty-tab { text-align:center; padding:40px; color:#9ca3af; font-size:.9rem; }
</style>

<div class="container-fluid py-4" style="max-width:1100px;">

    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 style="font-size:1.35rem;font-weight:700;margin:0 0 4px;">
                    <i class="bi bi-clipboard-check me-2"></i>Office Assistant — Dashboard
                </h2>
                <p style="margin:0;opacity:.85;font-size:.88rem;">Karnataka Forest Department | Welcome, @User.Identity?.Name</p>
            </div>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
            </a>
        </div>
    </div>

    
    <div class="row g-3 mb-4">
        <div class="col-6 col-md">
            <div class="stat-card c1">
                <div class="stat-number text-warning">@Model.CountNew</div>
                <div class="stat-label">New Petitions</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="stat-card c2">
                <div class="stat-number text-primary">@Model.CountUnderScrutiny</div>
                <div class="stat-label">Under Scrutiny</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="stat-card c3">
                <div class="stat-number text-success">@Model.CountForAction</div>
                <div class="stat-label">Forwarded for Action</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="stat-card c4">
                <div class="stat-number text-danger">@Model.CountForDrop</div>
                <div class="stat-label">Forwarded for Drop</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="stat-card c5">
                <div class="stat-number" style="color:#d97706;">@Model.CountOADropped</div>
                <div class="stat-label">Dropped by OA</div>
            </div>
        </div>
    </div>

    
    <div class="d-flex gap-2 flex-wrap mb-3">
        <button class="tab-btn active" onclick="showTab('new',this)">
            New <span class="badge bg-warning text-dark ms-1">@Model.CountNew</span>
        </button>
        <button class="tab-btn" onclick="showTab('scrutiny',this)">
            Under Scrutiny <span class="badge bg-primary ms-1">@Model.CountUnderScrutiny</span>
        </button>
        <button class="tab-btn" onclick="showTab('foraction',this)">
            Forwarded — Action <span class="badge bg-success ms-1">@Model.CountForAction</span>
        </button>
        <button class="tab-btn" onclick="showTab('fordrop',this)">
            Forwarded — Drop <span class="badge bg-danger ms-1">@Model.CountForDrop</span>
        </button>
        <button class="tab-btn" onclick="showTab('oadropped',this)">
            Dropped by OA <span class="badge ms-1" style="background:#d97706;">@Model.CountOADropped</span>
        </button>
    </div>

    @{ 
        void RenderList(List<PMS.Web.Models.Entities.Petition> list, string rowClass, string badgeClass, string badgeText, string btnClass, string btnText, string btnColor)
        {
            if (!list.Any()) { <div class="empty-tab"><i class="bi bi-check-circle text-success fs-3"></i><br/>Nothing here</div> return; }
            foreach (var p in list)
            {
                <div class="petition-row @rowClass">
                    <div class="d-flex justify-content-between align-items-start">
                        <div style="flex:1;min-width:0;">
                            <div class="pid"># @p.PetitionApplicationId</div>
                            <div class="pcat">@(p.ComplaintCategory?.Name ?? "General")</div>
                            <div class="pdesc">@p.Description</div>
                            <div class="pdate mt-1">
                                <i class="bi bi-calendar3 me-1"></i>@p.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy")
                                @if (p.LocationDistrict != null) { <span class="ms-2"><i class="bi bi-geo-alt me-1"></i>@p.LocationDistrict.Name</span> }
                            </div>
                        </div>
                        <div class="ms-3 text-end">
                            <span class="bs @badgeClass">@badgeText</span>
                            <div class="mt-2">
                                <a href="/OfficeAssistant/PetitionDetail?id=@p.PetitionId"
                                   class="btn btn-act" style="background:@btnColor;color:white;">
                                    <i class="bi bi-eye me-1"></i>@btnText
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    }

    <div id="tab-new">@{ RenderList(Model.NewPetitions, "row-new", "bs-new", "New", "", "Scrutinize", "#f59e0b"); }</div>
    <div id="tab-scrutiny" style="display:none;">@{ RenderList(Model.UnderScrutiny, "row-scrutiny", "bs-scrutiny", "Under Scrutiny", "", "Continue", "#2563eb"); }</div>
    <div id="tab-foraction" style="display:none;">@{ RenderList(Model.ForAction, "row-forwarded", "bs-fwdact", "For Action", "", "View", "#1a5c2a"); }</div>
    <div id="tab-fordrop" style="display:none;">@{ RenderList(Model.ForDrop, "row-droprec", "bs-fwddrop", "For Drop", "", "View", "#dc2626"); }</div>
    <div id="tab-oadropped" style="display:none;">@{ RenderList(Model.OADropped, "row-dropped", "bs-oadrop", "Dropped by OA", "", "View", "#d97706"); }</div>

</div>

<script>
    function showTab(name, btn) {
        ['new','scrutiny','foraction','fordrop','oadropped'].forEach(t =>
            document.getElementById('tab-' + t).style.display = 'none');
        document.getElementById('tab-' + name).style.display = 'block';
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }
</script>
