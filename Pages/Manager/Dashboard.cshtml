@page
@model PMS.Web.Pages.Manager.DashboardModel
@{ ViewData["Title"] = "Manager Dashboard"; }

<style>
    .page-header { background:linear-gradient(135deg,#1a3a5c 0%,#1e6091 100%); color:white; padding:24px 32px; border-radius:10px; margin-bottom:28px; }
    .stat-card { background:#fff; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,.07); padding:20px 24px; border-left:4px solid #e5e7eb; }
    .stat-number { font-size:2rem; font-weight:700; color:#111827; }
    .stat-label  { font-size:.82rem; color:#6b7280; margin-top:2px; }

    .tab-btn { padding:7px 18px; border-radius:6px; border:1px solid #e5e7eb; background:#f9fafb; color:#374151; font-size:.83rem; font-weight:500; cursor:pointer; transition:all .15s; }
    .tab-btn.active,.tab-btn:hover { background:#1a3a5c; color:white; border-color:#1a3a5c; }

    .petition-row { background:#fff; border-radius:8px; box-shadow:0 1px 4px rgba(0,0,0,.06); padding:15px 20px; margin-bottom:10px; border-left:3px solid #e5e7eb; transition:box-shadow .15s; }
    .petition-row:hover { box-shadow:0 3px 12px rgba(0,0,0,.1); }

    .pid  { font-family:monospace; font-size:.78rem; color:#6b7280; }
    .pcat { font-weight:600; font-size:.93rem; color:#111827; }
    .pdesc { font-size:.81rem; color:#6b7280; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:420px; }
    .pdate { font-size:.75rem; color:#9ca3af; }

    .bs { display:inline-block; padding:3px 10px; border-radius:20px; font-size:.73rem; font-weight:600; white-space:nowrap; }
    .bs-new      { background:#fef3c7; color:#92400e; }
    .bs-oa       { background:#dbeafe; color:#1d4ed8; }
    .bs-sentback { background:#fce7f3; color:#9d174d; }
    .bs-summary  { background:#ede9fe; color:#5b21b6; }
    .bs-closed   { background:#d1fae5; color:#065f46; }

    .empty-tab { text-align:center; padding:40px; color:#9ca3af; font-size:.9rem; }
</style>

<div class="container-fluid py-4" style="max-width:1100px;">

    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 style="font-size:1.35rem;font-weight:700;margin:0 0 4px;">
                    <i class="bi bi-person-workspace me-2"></i>Manager — Dashboard
                </h2>
                <p style="margin:0;opacity:.85;font-size:.88rem;">
                    Karnataka Forest Department | @User.Identity?.Name
                </p>
            </div>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
            </a>
        </div>
    </div>

    @* Stats *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md">
            <div class="stat-card" style="border-left-color:#f59e0b;">
                <div class="stat-number text-warning">@Model.CountNew</div>
                <div class="stat-label">New Petitions</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="stat-card" style="border-left-color:#3b82f6;">
                <div class="stat-number text-primary">@Model.CountAssignedToOA</div>
                <div class="stat-label">With OA</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="stat-card" style="border-left-color:#db2777;">
                <div class="stat-number" style="color:#db2777;">@Model.CountSentBack</div>
                <div class="stat-label">Sent Back by APCCF</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="stat-card" style="border-left-color:#7c3aed;">
                <div class="stat-number" style="color:#7c3aed;">@Model.CountSummaryPending</div>
                <div class="stat-label">Summary</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="stat-card" style="border-left-color:#10b981;">
                <div class="stat-number text-success">@Model.CountClosed</div>
                <div class="stat-label">Closed</div>
            </div>
        </div>
    </div>

    @* Tabs *@
    <div class="d-flex gap-2 flex-wrap mb-3">
        <button class="tab-btn active" onclick="showTab('new', this)">
            New <span class="badge bg-warning text-dark ms-1">@Model.CountNew</span>
        </button>
        <button class="tab-btn" onclick="showTab('oa', this)">
            With OA <span class="badge bg-primary ms-1">@Model.CountAssignedToOA</span>
        </button>
        <button class="tab-btn" onclick="showTab('sentback', this)">
            Sent Back <span class="badge ms-1" style="background:#db2777;">@Model.CountSentBack</span>
        </button>
        <button class="tab-btn" onclick="showTab('summary', this)">
            Summary <span class="badge ms-1" style="background:#7c3aed;">@Model.CountSummaryPending</span>
        </button>
        <button class="tab-btn" onclick="showTab('closed', this)">
            Closed <span class="badge bg-success ms-1">@Model.CountClosed</span>
        </button>
    </div>

    @* New Petitions Tab *@
    <div id="tab-new">
        @if (!Model.NewPetitions.Any())
        {
            <div class="empty-tab"><i class="bi bi-inbox fs-3"></i><br/>No new petitions</div>
        }
        @foreach (var p in Model.NewPetitions)
        {
            <div class="petition-row" style="border-left-color:#f59e0b;">
                <div class="d-flex justify-content-between align-items-start">
                    <div style="flex:1;min-width:0;">
                        <div class="pid"># @p.PetitionApplicationId</div>
                        <div class="pcat">@(p.ComplaintCategory?.Name ?? "General")</div>
                        <div class="pdesc">@p.Description</div>
                        <div class="pdate mt-1">
                            <i class="bi bi-calendar3 me-1"></i>@p.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy")
                            @if (p.LocationDistrict != null) { <span class="ms-2"><i class="bi bi-geo-alt me-1"></i>@p.LocationDistrict.Name</span> }
                        </div>
                    </div>
                    <div class="ms-3 text-end">
                        <span class="bs bs-new">New</span>
                        <div class="mt-2">
                            <a href="/Manager/PetitionDetail?id=@p.PetitionId"
                               class="btn btn-warning btn-sm" style="font-size:.78rem;">
                                <i class="bi bi-person-plus me-1"></i>Assign OA
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* With OA Tab *@
    <div id="tab-oa" style="display:none;">
        @if (!Model.AssignedToOA.Any())
        {
            <div class="empty-tab">No petitions with OA</div>
        }
        @foreach (var p in Model.AssignedToOA)
        {
            <div class="petition-row" style="border-left-color:#3b82f6;">
                <div class="d-flex justify-content-between align-items-start">
                    <div style="flex:1;min-width:0;">
                        <div class="pid"># @p.PetitionApplicationId</div>
                        <div class="pcat">@(p.ComplaintCategory?.Name ?? "General")</div>
                        <div class="pdesc">@p.Description</div>
                        <div class="pdate mt-1">
                            @if (p.AssignedOA != null)
                            {
                                <span><i class="bi bi-person me-1"></i>OA: @p.AssignedOA.Name</span>
                            }
                        </div>
                    </div>
                    <div class="ms-3 text-end">
                        <span class="bs bs-oa">With OA</span>
                        <div class="mt-2">
                            <a href="/Manager/PetitionDetail?id=@p.PetitionId"
                               class="btn btn-primary btn-sm" style="font-size:.78rem;">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Sent Back Tab *@
    <div id="tab-sentback" style="display:none;">
        @if (!Model.SentBack.Any())
        {
            <div class="empty-tab">No petitions sent back by APCCF</div>
        }
        @foreach (var p in Model.SentBack)
        {
            <div class="petition-row" style="border-left-color:#db2777; background:#fff5f8;">
                <div class="d-flex justify-content-between align-items-start">
                    <div style="flex:1;min-width:0;">
                        <div class="pid"># @p.PetitionApplicationId</div>
                        <div class="pcat">@(p.ComplaintCategory?.Name ?? "General")</div>
                        <div class="pdesc">@p.Description</div>
                        <div class="pdate mt-1">
                            <i class="bi bi-arrow-return-left text-danger me-1"></i>
                            Sent back by APCCF for summary review
                        </div>
                    </div>
                    <div class="ms-3 text-end">
                        <span class="bs bs-sentback">Sent Back</span>
                        <div class="mt-2">
                            <a href="/Manager/PetitionDetail?id=@p.PetitionId"
                               class="btn btn-sm" style="background:#db2777;color:white;font-size:.78rem;">
                                <i class="bi bi-person-plus me-1"></i>Assign OA for Summary
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Summary Tab *@
    <div id="tab-summary" style="display:none;">
        @if (!Model.SummaryPending.Any())
        {
            <div class="empty-tab">No summary pending</div>
        }
        @foreach (var p in Model.SummaryPending)
        {
            <div class="petition-row" style="border-left-color:#7c3aed;">
                <div class="d-flex justify-content-between align-items-start">
                    <div style="flex:1;min-width:0;">
                        <div class="pid"># @p.PetitionApplicationId</div>
                        <div class="pcat">@(p.ComplaintCategory?.Name ?? "General")</div>
                        <div class="pdesc">@p.Description</div>
                        <div class="pdate mt-1">
                            Status: <strong>@p.Status</strong>
                        </div>
                    </div>
                    <div class="ms-3 text-end">
                        <span class="bs bs-summary">Summary</span>
                        <div class="mt-2">
                            <a href="/Manager/PetitionDetail?id=@p.PetitionId"
                               class="btn btn-secondary btn-sm" style="font-size:.78rem;">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Closed Tab *@
    <div id="tab-closed" style="display:none;">
        @if (!Model.Closed.Any())
        {
            <div class="empty-tab">No closed petitions</div>
        }
        @foreach (var p in Model.Closed)
        {
            <div class="petition-row" style="border-left-color:#10b981;">
                <div class="d-flex justify-content-between align-items-start">
                    <div style="flex:1;min-width:0;">
                        <div class="pid"># @p.PetitionApplicationId</div>
                        <div class="pcat">@(p.ComplaintCategory?.Name ?? "General")</div>
                        <div class="pdesc">@p.Description</div>
                    </div>
                    <div class="ms-3 text-end">
                        <span class="bs bs-closed">Closed</span>
                        <div class="mt-2">
                            <a href="/Manager/PetitionDetail?id=@p.PetitionId"
                               class="btn btn-secondary btn-sm" style="font-size:.78rem;">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

</div>

<script>
    function showTab(name, btn) {
        ['new','oa','sentback','summary','closed'].forEach(t =>
            document.getElementById('tab-' + t).style.display = 'none');
        document.getElementById('tab-' + name).style.display = 'block';
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }
</script>
