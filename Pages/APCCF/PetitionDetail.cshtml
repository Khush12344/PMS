</style>

<div class="container py-4" style="max-width:980px;">

    @if (p == null)
    {
        <div class="alert alert-warning">Petition not found.</div>
    }
    else
    {
        <div class="page-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <div style="font-size:.8rem;opacity:.8;"># @p.PetitionApplicationId</div>
                    <h2 class="mb-0" style="font-size:1.25rem;">@(p.ComplaintCategory?.Name ?? "Petition Detail")</h2>
                </div>
                <span class="badge-status @GetStatusClass(p.Status)">@GetStatusLabel(p.Status)</span>
            </div>
        </div>

        <a href="/APCCF/Dashboard" class="btn btn-outline-secondary btn-sm mb-3">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success mb-3"><i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-3"><i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage</div>
        }

        <div class="row g-4">
            <div class="col-lg-7">

                @* Complainant *@
                <div class="detail-card">
                    <div class="section-title">Petition</div>
                    <div class="detail-row"><span class="detail-label">Name</span><span class="detail-value">@(p.ComplainantName ?? "—")</span></div>
                    <div class="detail-row"><span class="detail-label">Mobile</span><span class="detail-value">@p.MobileNumber</span></div>
                    @if (!string.IsNullOrEmpty(p.HouseNo) || !string.IsNullOrEmpty(p.Street))
                    {
                        <div class="detail-row">
                            <span class="detail-label">Address</span>
                            <span class="detail-value">@string.Join(", ", new[] { p.HouseNo, p.Street, p.Area }.Where(s => !string.IsNullOrEmpty(s)))</span>
                        </div>
                    }
                    <div class="detail-row">
                        <span class="detail-label">District / Taluk</span>
                        <span class="detail-value">
                            @(p.ComplainantDistrict?.Name ?? "—")@if(p.ComplainantTaluk!=null){
                            <text> / @p.ComplainantTaluk.Name</text>
                        }
                    </span>
                </div>
            </div>

            @* Complaint *@
            <div class="detail-card">
                <div class="section-title">Petition Details</div>
                <div class="detail-row"><span class="detail-label">Category</span><span class="detail-value">@(p.ComplaintCategory?.Name ?? "—")</span></div>
                <div class="detail-row"><span class="detail-label">Submitted</span><span class="detail-value">@p.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</span></div>
                <div class="detail-row">
                    <span class="detail-label">Incident Location</span>
                    <span class="detail-value">
                        @(p.LocationDistrict?.Name ?? "—")@if(p.LocationTaluk!=null){
                        <text> / @p.LocationTaluk.Name</text>
                                                }
                    </span>
                </div>
                <div class="mt-3">
                    <div class="detail-label mb-1">Description</div>
                    <div class="desc-box">@p.Description</div>
                </div>
            </div>

            @* Attachments *@
            @if (p.Attachments.Any())
            {
                <div class="detail-card">
                    <div class="section-title">Attachments</div>
                    @{
                        var docs = p.Attachments.Where(a => a.FileType == PMS.Web.Models.Enums.AttachmentType.Document).ToList();
                    }
                    @{
                        var photos = p.Attachments.Where(a => a.FileType == PMS.Web.Models.Enums.AttachmentType.Photo).ToList();
                    }
                    @if (docs.Any())
                    {
                        <div class="mb-2">
                            <div style="font-size:.8rem;font-weight:700;color:#6b7280;margin-bottom:6px;"><i class="bi bi-file-earmark-pdf text-danger me-1"></i>DOCUMENTS</div>
                            @foreach (var a in docs)
                            {
                                <a href="/uploads/petitions/@p.PetitionId/@a.StoredFileName" target="_blank" class="attach-item">
                                    <i class="bi bi-file-earmark-pdf text-danger"></i> @a.OriginalFileName
                                    <span style="color:#9ca3af;">(@((a.FileSizeBytes / 1024.0).ToString("0.#"))KB)</span>
                                </a>
                            }
                        </div>
                    }
                    @if (photos.Any())
                    {
                        <div>
                            <div style="font-size:.8rem;font-weight:700;color:#6b7280;margin-bottom:6px;"><i class="bi bi-image text-success me-1"></i>PHOTOS</div>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var a in photos)
                                {
                                    <img src="/uploads/petitions/@p.PetitionId/@a.StoredFileName"
                                         class="attach-img" onclick="openLightbox(this.src)" title="@a.OriginalFileName" />
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @* Action Reports *@
            @if (p.ActionReports.Any())
            {
                <div class="detail-card">
                    <div class="section-title">Field Office Reports</div>
                    @foreach (var r in p.ActionReports)
                    {
                        <div class="report-card">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="report-type @(r.ReportType == PMS.Web.Models.Enums.ReportType.Final ? "rt-final" : "rt-interim")">
                                    @r.ReportType Report
                                </span>
                                <span style="font-size:.75rem;color:#9ca3af;">@r.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</span>
                            </div>
                            <div style="font-size:.87rem;color:#374151;line-height:1.6;">@r.ReportText</div>
                            @if (r.Attachments.Any())
                            {
                                <div class="mt-2">
                                    @foreach (var a in r.Attachments)
                                    {
                                        <a href="/uploads/reports/@r.ReportId/@a.StoredFileName" target="_blank" class="attach-item">
                                            <i class="bi bi-paperclip"></i> @a.OriginalFileName
                                        </a>
                                    }
                                </div>
                            }
                            @if (r.IsApproved.HasValue)
                            {
                                <div class="mt-2 p-2 rounded" style="background:@(r.IsApproved.Value ? "#f0fdf4" : "#fff5f5");font-size:.82rem;">
                                    <strong>APCCF Decision:</strong> @(r.IsApproved.Value ? "✅ Accepted" : "❌ Rejected")
                                    @if (!string.IsNullOrEmpty(r.APCCFDecisionRemarks))
                                    {
                                        <span> — @r.APCCFDecisionRemarks</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

        </div>

        <div class="col-lg-5">

            @* OA Recommendation *@
            @if (p.OARecommendation.HasValue || isOADropped)
            {
                <div class="detail-card">
                    <div class="section-title">OA Recommendation</div>
                    @if (isOADropped)
                    {
                        <div class="oa-rec-box oa-rec-direct">
                            <div style="font-weight:700;font-size:.88rem;color:#92400e;">⚠ Dropped by Office Assistant</div>
                            <div style="font-size:.83rem;margin-top:6px;"><strong>Reason:</strong> @p.OADropReason</div>
                            <div style="font-size:.75rem;color:#9ca3af;margin-top:4px;">@p.OADroppedAt?.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                        </div>
                    }
                    else if (p.OARecommendation == PMS.Web.Models.Enums.OARecommendation.ForAction)
                    {
                        <div class="oa-rec-box oa-rec-action">
                            <div style="font-weight:700;font-size:.88rem;color:#065f46;">✅ Recommended For Action</div>
                            @if (p.RecommendedOfficer != null)
                            {
                                <div style="font-size:.83rem;margin-top:6px;">
                                    Suggested Officer: <strong>@p.RecommendedOfficer.Name</strong>
                                    (@p.RecommendedOfficeType)
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(p.OARemarks))
                            {
                                <div style="font-size:.82rem;color:#6b7280;margin-top:4px;">@p.OARemarks</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="oa-rec-box oa-rec-drop">
                            <div style="font-weight:700;font-size:.88rem;color:#991b1b;">❌ Recommended For Drop</div>
                            @if (!string.IsNullOrEmpty(p.OARemarks))
                            {
                                <div style="font-size:.83rem;margin-top:6px;">@p.OARemarks</div>
                            }
                        </div>
                    }
                    @if (p.ScrutinizedBy != null)
                    {
                        <div style="font-size:.78rem;color:#9ca3af;margin-top:8px;">
                            Scrutinized by: @p.ScrutinizedBy.Name
                        </div>
                    }
                </div>
            }

            @* Assignment Info *@
            @if (p.AssignedOfficer != null)
            {
                <div class="detail-card">
                    <div class="section-title">Assignment</div>
                    <div class="detail-row"><span class="detail-label">Office</span><span class="detail-value">@p.AssignedOfficer.Name</span></div>
                    <div class="detail-row"><span class="detail-label">Office Type</span><span class="detail-value">@p.AssignedOfficeType</span></div>
                    @if (p.AssignedAt.HasValue)
                    {
                        <div class="detail-row"><span class="detail-label">Assigned On</span><span class="detail-value">@p.AssignedAt.Value.ToLocalTime().ToString("dd MMM yyyy")</span></div>
                    }
                    @if (!string.IsNullOrEmpty(p.APCCFRemarks))
                    {
                        <div class="detail-row"><span class="detail-label">Remarks</span><span class="detail-value">@p.APCCFRemarks</span></div>
                    }
                </div>
            }

            @* Timeline *@
            @if (p.WorkflowLogs.Any())
            {
                <div class="detail-card">
                    <div class="section-title">Timeline</div>
                    <div class="timeline">
                        @foreach (var log in p.WorkflowLogs.OrderBy(l => l.ActionAt))
                        {
                            <div class="timeline-item">
                                <div class="tl-dot"></div>
                                <div class="tl-label">@(log.PublicLabel ?? log.Action)</div>
                                @if (log.ActorUser != null)
                                {
                                    <div class="tl-by">by @log.ActorUser.Name</div>
                                }
                                <div class="tl-date">@log.ActionAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                                @if (!string.IsNullOrEmpty(log.InternalRemarks))
                                {
                                    <div style="font-size:.75rem;color:#6b7280;margin-top:2px;">@log.InternalRemarks</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @* ══════════════════════════════════════════
               APCCF ACTIONS  — accordion style
               ══════════════════════════════════════════ *@
            @if (!isClosed && !isDropped)
            {
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="PetitionId" value="@p.PetitionId" />

                    @* ── Pending Closure: Final Report Decision ── *@
                    @if (isPendingClosure || isSummary)
                    {
                        var finalReport = p.ActionReports.FirstOrDefault(r =>
                        r.ReportType == PMS.Web.Models.Enums.ReportType.Final && !r.IsApproved.HasValue);
                        if (finalReport != null)
                        {
                            <input type="hidden" name="ReportId" value="@finalReport.ReportId" />

                            <div class="acc-group-label">Final Report Decision</div>

                            
                            <div class="acc-wrap">
                                <div class="acc-title acc-accept" onclick="toggleAcc(this)">
                                    <span><i class="bi bi-check-circle me-2"></i>Accept &amp; Close Petition</span>
                                    <span class="chevron">▼</span>
                                </div>
                                <div class="acc-body">
                                    <p style="font-size:.82rem;color:#374151;margin-bottom:12px;">
                                        Accept the final report and close this petition.
                                    </p>
                                    <div class="mb-3">
                                        <label class="form-label">Remarks</label>
                                        <textarea name="Remarks" class="form-control" rows="2"
                                      placeholder="Add your remarks..."></textarea>
                                    </div>
                                    <button type="submit" name="action" value="accept" class="btn-accept btn w-100">
                                        <i class="bi bi-check-circle me-1"></i>Accept &amp; Close
                                    </button>
                                </div>
                            </div>

                           
                            <div class="acc-wrap">
                                <div class="acc-title acc-resend" onclick="toggleAcc(this)">
                                    <span><i class="bi bi-arrow-counterclockwise me-2"></i> Resend to Same Officer</span>
                                    <span class="chevron">▼</span>
                                </div>
                                <div class="acc-body">
                                    <p style="font-size:.82rem;color:#374151;margin-bottom:12px;">
                                        Resend the report back to the same office for revision.
                                    </p>
                                    <div class="mb-3">
                                        <label class="form-label">Remarks</label>
                                        <textarea name="Remarks" class="form-control" rows="2"
                                      placeholder="Reason for rejection..."></textarea>
                                    </div>
                                    <button type="submit" name="action" value="resend" class="btn-resend btn w-100">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i>Resend Seeking Clarification
                                    </button>
                                </div>
                            </div>

                            
                            <div class="acc-wrap">
                                <div class="acc-title acc-reassign" onclick="toggleAcc(this)">
                                    <span><i class="bi bi-person-x me-2"></i> Reassign to other Office</span>
                                    <span class="chevron">▼</span>
                                </div>
                                <div class="acc-body">
                                    <div class="row g-2 mb-3">
                                        <div class="col-6">
                                            <label class="form-label">New Office Type</label>
                                            <select name="OfficeType" class="form-select form-select-sm"
                                                    onchange="filterOfficers(this.value, 'reassignOfficer')">
                                                <option value="">— Select —</option>
                                                <option value="Circle">Circle</option>
                                                <option value="Division">Division</option>
                                                <option value="FMSDivision">FMS Division</option>
                                            </select>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">New Office</label>
                                            <select name="AssignedOfficerId" id="reassignOfficer" class="form-select form-select-sm">
                                                <option value="">— Select Officer —</option>
                                                @foreach (var o in Model.FieldOfficers)
                                                {
                                                    <option value="@o.UserId" data-office="@o.OfficeType">@o.Name</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Remarks</label>
                                        <textarea name="Remarks" class="form-control" rows="2"
                                      placeholder="Reason for reassignment..."></textarea>
                                    </div>
                                    <button type="submit" name="action" value="reassign" class="btn-reassign btn w-100">
                                        <i class="bi bi-person-x me-1"></i>Resend &amp; Reassign
                                    </button>
                                </div>
                            </div>
                        }
                    }

                    @* ── canAssign: Assign / Override + Drop ── *@
                    @if (canAssign)
                    {
                        <div class="acc-group-label mt-3">Actions</div>

                        <div class="acc-wrap">
                            <div class="acc-title @(isOADropped ? "acc-override" : "acc-assign")" onclick="toggleAcc(this)">
                                <span>
                                    @if (isOADropped)
                                    {
                                        <i class="bi bi-shield-check me-2"></i>
                            
                                        <text>Override &amp; Assign to Officer</text>
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-check me-2"></i>
                            
                                        <text>Assign to Field Officer</text>
                                    }
                                </span>
                                <span class="chevron">▼</span>
                            </div>
                            <div class="acc-body">
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <label class="form-label">Office Type</label>
                                        <select name="OfficeType" class="form-select form-select-sm"
                                                onchange="filterOfficers(this.value, 'assignOfficer')">
                                            <option value="">— Select —</option>
                                            <option value="Circle">Circle</option>
                                            <option value="Division">Division</option>
                                            <option value="FMSDivision">FMS Division</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Officer</label>
                                        <select name="AssignedOfficerId" id="assignOfficer" class="form-select form-select-sm">
                                            <option value="">— Select Officer —</option>
                                            @foreach (var o in Model.FieldOfficers)
                                            {
                                                <option value="@o.UserId" data-office="@o.OfficeType">@o.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Remarks <span style="font-size:.78rem;color:#9ca3af;">(Optional)</span></label>
                                    <textarea name="Remarks" class="form-control" rows="2"
                                      placeholder="Add remarks..."></textarea>
                                </div>
                                <button type="submit"
                                        name="action"
                                        value="@(isOADropped ? "override" : "assign")"
                                        class="@(isOADropped ? "btn-override" : "btn-assign") btn w-100">
                                    <i class="bi bi-send me-1"></i>
                                    @(isOADropped ? "Override & Assign" : "Assign Officer")
                                </button>
                            </div>
                        </div>

                       
                        <div class="acc-wrap">
                            <div class="acc-title acc-drop" onclick="toggleAcc(this)">
                                <span><i class="bi bi-x-circle me-2"></i>Drop Petition</span>
                                <span class="chevron">▼</span>
                            </div>
                            <div class="acc-body">
                                <div class="mb-3">
                                    <label class="form-label">Drop Reason <span class="text-danger">*</span></label>
                                    <input type="text" name="DropReason" class="form-control form-control-sm"
                                           placeholder="Reason for dropping this petition..." />
                                </div>
                                <button type="submit" name="action" value="drop"
                                        class="btn-drop btn w-100"
                                        onclick="return confirm('Are you sure you want to drop this petition?')">
                                    <i class="bi bi-x-circle me-1"></i>Drop Petition
                                </button>
                            </div>
                        </div>
                    }

                    @* ── canSendToManager: Drop + Send to Manager ── *@
                    @if (canSendToManager)
                    {
                        <div class="acc-group-label mt-3">Actions</div>

                        
                        <div class="acc-wrap">
                            <div class="acc-title acc-drop" onclick="toggleAcc(this)">
                                <span><i class="bi bi-x-circle me-2"></i>Drop Petition</span>
                                <span class="chevron">▼</span>
                            </div>
                            <div class="acc-body">
                                <div class="mb-3">
                                    <label class="form-label">Drop Reason <span class="text-danger">*</span></label>
                                    <input type="text" name="DropReason" class="form-control form-control-sm"
                                           placeholder="Reason..." />
                                </div>
                                <button type="submit" name="action" value="drop"
                                        class="btn-drop btn w-100"
                                        onclick="return confirm('Drop this petition?')">
                                    <i class="bi bi-x-circle me-1"></i>Drop
                                </button>
                            </div>
                        </div>

                       
                        <div class="acc-wrap">
                            <div class="acc-title acc-manager" onclick="toggleAcc(this)">
                                <span><i class="bi bi-arrow-return-left me-2"></i>Send to Manager</span>
                                <span class="chevron">▼</span>
                            </div>
                            <div class="acc-body">
                                <div class="mb-3">
                                    <label class="form-label">Remarks <span class="text-danger">*</span></label>
                                    <textarea name="Remarks" class="form-control form-control-sm" rows="2"
                                      placeholder="Reason for sending to Manager..."></textarea>
                                </div>
                                <button type="submit"
                                        name="action"
                                        value="sendtomanager"
                                        class="btn-manager btn w-100">
                                    <i class="bi bi-send me-1"></i>Send to Manager
                                </button>
                            </div>
                        </div>
                    }

                </form>
            }

            @* Final state *@
            @if (isClosed)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <strong>Petition Closed</strong> — This petition has been resolved and closed.
                </div>
            }
            @if (isDropped)
            {
                <div class="alert alert-secondary">
                    <i class="bi bi-x-circle-fill me-2"></i>
                    <strong>Petition Dropped</strong> — @p.APCCFRemarks
                </div>
            }

        </div>
    </div>
        }
</div>

@* Lightbox *@
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <span class="lightbox-close">&times;</span>
    <img id="lightboxImg" src="" />
</div>

<script>
    /* ── Accordion toggle ── */
    function toggleAcc(titleEl) {
        var isOpen = titleEl.classList.contains('open');

        /* Close all siblings in the same form first (optional: remove these 3 lines for independent accordions) */
        titleEl.closest('form').querySelectorAll('.acc-title').forEach(function(t) {
            t.classList.remove('open');
            t.nextElementSibling.classList.remove('open');
        });

        /* If it wasn't open, open it now */
        if (!isOpen) {
            titleEl.classList.add('open');
            titleEl.nextElementSibling.classList.add('open');
        }
    }

    /* ── Officer filter ── */
    function filterOfficers(officeType, selectId) {
        var sel = document.getElementById(selectId);
        if (!sel) return;
        sel.querySelectorAll('option[data-office]').forEach(function(o) {
            o.style.display = (!officeType || o.dataset.office === officeType) ? '' : 'none';
        });
        sel.value = '';
    }

    /* ── Lightbox ── */
    function openLightbox(src) {
        document.getElementById('lightboxImg').src = src;
        document.getElementById('lightbox').classList.add('open');
    }
    function closeLightbox() {
        document.getElementById('lightbox').classList.remove('open');
    }
</script>

@functions {
    string GetStatusClass(PMS.Web.Models.Enums.PetitionStatus s) => s switch
    {
        PMS.Web.Models.Enums.PetitionStatus.Submitted => "bs-new",
        PMS.Web.Models.Enums.PetitionStatus.UnderScrutiny => "bs-scrutiny",
        PMS.Web.Models.Enums.PetitionStatus.OADropped => "bs-oadrop",
        PMS.Web.Models.Enums.PetitionStatus.RecommendedForAction => "bs-action",
        PMS.Web.Models.Enums.PetitionStatus.RecommendedForDrop => "bs-droprec",
        PMS.Web.Models.Enums.PetitionStatus.Assigned => "bs-assigned",
        PMS.Web.Models.Enums.PetitionStatus.InProgress => "bs-inprog",
        PMS.Web.Models.Enums.PetitionStatus.SubmittedForClosure => "bs-closure",
        PMS.Web.Models.Enums.PetitionStatus.Closed => "bs-closed",
        PMS.Web.Models.Enums.PetitionStatus.Dropped => "bs-dropped",
        _ => "bs-new"
    };
    string GetStatusLabel(PMS.Web.Models.Enums.PetitionStatus s) => s switch
    {
        PMS.Web.Models.Enums.PetitionStatus.Submitted => "New",
        PMS.Web.Models.Enums.PetitionStatus.UnderScrutiny => "Under Scrutiny",
        PMS.Web.Models.Enums.PetitionStatus.OADropped => "Dropped by OA",
        PMS.Web.Models.Enums.PetitionStatus.RecommendedForAction => "For Action",
        PMS.Web.Models.Enums.PetitionStatus.RecommendedForDrop => "For Drop",
        PMS.Web.Models.Enums.PetitionStatus.Assigned => "Assigned",
        PMS.Web.Models.Enums.PetitionStatus.InProgress => "In Progress",
        PMS.Web.Models.Enums.PetitionStatus.SubmittedForClosure => "Pending Closure",
        PMS.Web.Models.Enums.PetitionStatus.Closed => "Closed",
        PMS.Web.Models.Enums.PetitionStatus.Dropped => "Dropped",
        _ => s.ToString()
    };
}
