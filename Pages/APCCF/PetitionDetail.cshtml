@page
@model PMS.Web.Pages.APCCF.PetitionDetailModel
@{
    ViewData["Title"] = "Petition Detail — APCCF";
    var p = Model.Petition;
    bool isOADropped = p?.Status == PMS.Web.Models.Enums.PetitionStatus.OADropped;
    bool isForAction = p?.Status == PMS.Web.Models.Enums.PetitionStatus.RecommendedForAction;
    bool isForDrop = p?.Status == PMS.Web.Models.Enums.PetitionStatus.RecommendedForDrop;
    bool isSubmitted = p?.Status == PMS.Web.Models.Enums.PetitionStatus.Submitted;
    bool isUnderScrutiny = p?.Status == PMS.Web.Models.Enums.PetitionStatus.UnderScrutiny;
    bool isAssigned = p?.Status == PMS.Web.Models.Enums.PetitionStatus.Assigned;
    bool isInProgress = p?.Status == PMS.Web.Models.Enums.PetitionStatus.InProgress;
    bool isPendingClosure = p?.Status == PMS.Web.Models.Enums.PetitionStatus.SubmittedForClosure;
    bool isClosed = p?.Status == PMS.Web.Models.Enums.PetitionStatus.Closed;
    bool isDropped = p?.Status == PMS.Web.Models.Enums.PetitionStatus.Dropped;
    bool isSummary = p.Status == PMS.Web.Models.Enums.PetitionStatus.SummarySubmitted;
    bool canAssign = isSubmitted || isUnderScrutiny || isForAction || isForDrop || isOADropped;
    var canSendToManager = p.Status == PMS.Web.Models.Enums.PetitionStatus.SubmittedForClosure
                    || p.Status == PMS.Web.Models.Enums.PetitionStatus.InProgress;
}

<style>
    .page-header {
        background: linear-gradient(135deg,#1a3a5c 0%,#2563eb 100%);
        color: white;
        padding: 22px 28px;
        border-radius: 10px;
        margin-bottom: 24px;
    }

    .detail-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        padding: 22px 26px;
        margin-bottom: 20px;
    }

    .section-title {
        font-size: .85rem;
        font-weight: 700;
        color: #1a3a5c;
        border-left: 3px solid #2563eb;
        padding-left: 10px;
        margin-bottom: 16px;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .detail-row {
        display: flex;
        margin-bottom: 10px;
        align-items: flex-start;
    }

    .detail-label {
        font-size: .82rem;
        color: #6b7280;
        font-weight: 500;
        min-width: 160px;
    }

    .detail-value {
        font-size: .88rem;
        color: #111827;
        font-weight: 500;
    }

    .desc-box {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 14px 16px;
        font-size: .88rem;
        color: #374151;
        line-height: 1.6;
    }

    .attach-item {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 5px 12px;
        font-size: .8rem;
        margin: 4px;
        color: #374151;
        text-decoration: none;
    }

        .attach-item:hover {
            background: #e5e7eb;
        }

    .attach-img {
        width: 80px;
        height: 60px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #e5e7eb;
        cursor: pointer;
    }

    .action-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        padding: 0;
        margin-bottom: 16px;
        overflow: hidden;
    }

    .action-card-header {
        padding: 14px 20px;
        font-weight: 700;
        font-size: .9rem;
    }

    /* ── Accordion styles ── */
    .acc-wrap {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        margin-bottom: 16px;
        overflow: hidden;
    }

    .acc-title {
        padding: 14px 18px 14px 20px;
        font-size: .88rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        user-select: none;
        transition: background .15s;
    }

        .acc-title:hover {
            filter: brightness(.97);
        }

        .acc-title .chevron {
            font-size: .75rem;
            transition: transform .25s;
        }

        .acc-title.open .chevron {
            transform: rotate(180deg);
        }

    .acc-body {
        display: none;
        padding: 16px 20px 20px;
        border-top: 1px solid rgba(0,0,0,.07);
    }

        .acc-body.open {
            display: block;
        }

    /* Colour skins for each accordion header */
    .acc-assign {
        background: #f0fdf4;
        color: #065f46;
        border-left: 4px solid #22c55e;
    }

    .acc-drop {
        background: #fff5f5;
        color: #991b1b;
        border-left: 4px solid #ef4444;
    }

    .acc-override {
        background: #fffbeb;
        color: #92400e;
        border-left: 4px solid #f59e0b;
    }

    .acc-manager {
        background: #fffbeb;
        color: #92400e;
        border-left: 4px solid #f59e0b;
    }

    .acc-accept {
        background: #f0fdf4;
        color: #065f46;
        border-left: 4px solid #22c55e;
    }

    .acc-resend {
        background: #f5f3ff;
        color: #5b21b6;
        border-left: 4px solid #8b5cf6;
    }

    .acc-reassign {
        background: #fff5f5;
        color: #991b1b;
        border-left: 4px solid #ef4444;
    }

    .form-label {
        font-weight: 500;
        font-size: .875rem;
        color: #374151;
    }

    .form-control, .form-select {
        border-radius: 6px;
        border: 1px solid #d1d5db;
        font-size: .88rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,.1);
        }

    .btn-assign {
        background: #1a5c2a;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 7px;
        font-weight: 600;
        font-size: .85rem;
    }

    .btn-drop {
        background: #dc2626;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 7px;
        font-weight: 600;
        font-size: .85rem;
    }

    .btn-override {
        background: #d97706;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 7px;
        font-weight: 600;
        font-size: .85rem;
    }

    .btn-accept {
        background: #1a5c2a;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 7px;
        font-weight: 600;
        font-size: .85rem;
    }

    .btn-resend {
        background: #7c3aed;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 7px;
        font-weight: 600;
        font-size: .85rem;
    }

    .btn-reassign {
        background: #dc2626;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 7px;
        font-weight: 600;
        font-size: .85rem;
    }

    .btn-manager {
        background: #d97706;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 7px;
        font-weight: 600;
        font-size: .85rem;
    }

    .badge-status {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 600;
    }

    .bs-new {
        background: #fef3c7;
        color: #92400e;
    }

    .bs-scrutiny {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .bs-oadrop {
        background: #fef3c7;
        color: #b45309;
    }

    .bs-action {
        background: #d1fae5;
        color: #065f46;
    }

    .bs-droprec {
        background: #fee2e2;
        color: #991b1b;
    }

    .bs-assigned {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .bs-inprog {
        background: #ede9fe;
        color: #5b21b6;
    }

    .bs-closure {
        background: #fce7f3;
        color: #9d174d;
    }

    .bs-closed {
        background: #d1fae5;
        color: #065f46;
    }

    .bs-dropped {
        background: #fee2e2;
        color: #991b1b;
    }

    .oa-rec-box {
        border-radius: 8px;
        padding: 14px 16px;
        margin-bottom: 12px;
    }

    .oa-rec-action {
        background: #f0fdf4;
        border: 1px solid #86efac;
    }

    .oa-rec-drop {
        background: #fff5f5;
        border: 1px solid #fca5a5;
    }

    .oa-rec-direct {
        background: #fffbeb;
        border: 1px solid #fcd34d;
    }

    .timeline {
        position: relative;
        padding-left: 28px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 10px;
            top: 8px;
            bottom: 8px;
            width: 2px;
            background: #e5e7eb;
        }

    .timeline-item {
        position: relative;
        margin-bottom: 18px;
    }

    .tl-dot {
        position: absolute;
        left: -24px;
        top: 4px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: #2563eb;
        border: 2px solid #fff;
        box-shadow: 0 0 0 2px #bfdbfe;
    }

    .tl-label {
        font-weight: 600;
        font-size: .87rem;
        color: #111827;
    }

    .tl-by {
        font-size: .75rem;
        color: #6b7280;
        margin-top: 1px;
    }

    .tl-date {
        font-size: .75rem;
        color: #9ca3af;
        margin-top: 1px;
    }

    .report-card {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 12px;
    }

    .report-type {
        font-size: .75rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 10px;
    }

    .rt-interim {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .rt-final {
        background: #ede9fe;
        color: #5b21b6;
    }

    .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.85);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }

        .lightbox.open {
            display: flex;
        }

        .lightbox img {
            max-width: 90vw;
            max-height: 90vh;
            border-radius: 8px;
        }

    .lightbox-close {
        position: absolute;
        top: 20px;
        right: 28px;
        color: white;
        font-size: 2rem;
        cursor: pointer;
    }

    /* section label for accordion groups */
    .acc-group-label {
        font-size: .78rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
