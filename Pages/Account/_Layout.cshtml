<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aranya Helpline</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&family=Noto+Serif:wght@600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        :root {
            --forest-dark:    #1B4332;
            --forest-mid:     #2D6A4F;
            --forest-light:   #52B788;
            --forest-pale:    #D8F3DC;
            --gold:           #E9C46A;
            --text-dark:      #1a1a1a;
            --text-muted:     #6c757d;
            --border-light:   #dee2e6;
            --white:          #ffffff;
            --bg-light:       #f8faf8;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Noto Sans', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Top Header Bar ─────────────────────────────── */
        .top-bar {
            background: var(--forest-dark);
            color: rgba(255,255,255,0.7);
            font-size: 0.75rem;
            padding: 5px 0;
            border-bottom: 2px solid var(--gold);
        }

        /* ── Main Header ────────────────────────────────── */
        .main-header {
            background: linear-gradient(135deg, var(--forest-dark) 0%, var(--forest-mid) 100%);
            padding: 16px 0;
            box-shadow: 0 2px 12px rgba(0,0,0,0.2);
        }

        .main-header .logo-emblem {
            width: 60px;
            height: 60px;
            background: var(--white);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
            flex-shrink: 0;
        }

        .main-header .dept-name-kn {
            font-family: 'Noto Sans', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--gold);
            line-height: 1.3;
        }

        .main-header .dept-name-en {
            font-family: 'Noto Serif', serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--white);
            line-height: 1.2;
        }

        .main-header .dept-sub {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.75);
            font-weight: 400;
        }

        /* ── Navigation ─────────────────────────────────── */
        .main-nav {
            background: var(--forest-mid);
            border-bottom: 3px solid var(--forest-light);
        }

        .main-nav .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 10px 16px !important;
            transition: all 0.2s;
            border-bottom: 3px solid transparent;
            margin-bottom: -3px;
        }

        .main-nav .nav-link:hover,
        .main-nav .nav-link.active {
            color: var(--white) !important;
            background: rgba(255,255,255,0.1);
            border-bottom-color: var(--gold);
        }

        .main-nav .nav-link i {
            margin-right: 5px;
        }

        /* ── Page Content ───────────────────────────────── */
        .page-content {
            flex: 1;
            padding: 30px 0;
        }

        /* ── Cards ──────────────────────────────────────── */
        .card {
            border: 1px solid var(--border-light);
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .card-header-forest {
            background: linear-gradient(135deg, var(--forest-dark), var(--forest-mid));
            color: var(--white);
            border-radius: 10px 10px 0 0 !important;
            padding: 16px 20px;
        }

        .card-header-forest h5, .card-header-forest h4 {
            margin: 0;
            font-family: 'Noto Serif', serif;
            font-weight: 700;
        }

        /* ── Buttons ────────────────────────────────────── */
        .btn-forest {
            background: linear-gradient(135deg, var(--forest-dark), var(--forest-mid));
            color: var(--white);
            border: none;
            font-weight: 600;
            padding: 10px 24px;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .btn-forest:hover {
            background: linear-gradient(135deg, var(--forest-mid), var(--forest-dark));
            color: var(--white);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(27,67,50,0.3);
        }

        .btn-forest-outline {
            background: transparent;
            color: var(--forest-dark);
            border: 2px solid var(--forest-mid);
            font-weight: 600;
            padding: 9px 24px;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .btn-forest-outline:hover {
            background: var(--forest-mid);
            color: var(--white);
        }

        /* ── Form Controls ──────────────────────────────── */
        .form-control:focus, .form-select:focus {
            border-color: var(--forest-light);
            box-shadow: 0 0 0 0.2rem rgba(82,183,136,0.25);
        }

        .form-label {
            font-weight: 600;
            font-size: 0.875rem;
            color: var(--forest-dark);
            margin-bottom: 5px;
        }

        .section-title {
            font-family: 'Noto Serif', serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--forest-dark);
            border-left: 4px solid var(--forest-light);
            padding-left: 10px;
            margin-bottom: 16px;
        }

        /* ── Alerts ─────────────────────────────────────── */
        .alert-forest {
            background: var(--forest-pale);
            border: 1px solid var(--forest-light);
            color: var(--forest-dark);
            border-radius: 8px;
        }

        /* ── Footer ─────────────────────────────────────── */
        .main-footer {
            background: var(--forest-dark);
            color: rgba(255,255,255,0.7);
            font-size: 0.8rem;
            padding: 16px 0;
            margin-top: auto;
            border-top: 3px solid var(--forest-light);
        }

        .main-footer a {
            color: var(--gold);
            text-decoration: none;
        }

        /* ── Badge ──────────────────────────────────────── */
        .badge-status {
            font-size: 0.75rem;
            padding: 5px 10px;
            border-radius: 20px;
            font-weight: 600;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Top Bar -->
    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <span><i class="bi bi-geo-alt-fill me-1"></i>Karnataka Forest Department</span>
            <span>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="me-3"><i class="bi bi-person-fill me-1"></i>@User.Identity.Name</span>
                    <a href="/Account/Logout" class="text-warning text-decoration-none">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </a>
                }
                else
                {
                    <a href="/Account/Login" class="text-warning text-decoration-none">
                        <i class="bi bi-person-lock me-1"></i>Staff Login
                    </a>
                }
            </span>
        </div>
    </div>

    <!-- Main Header -->
    <header class="main-header">
        <div class="container">
            <div class="d-flex align-items-center gap-3">
                <div class="logo-emblem">🌿</div>
                <div>
                    <div class="dept-name-kn">ಅರಣ್ಯ ಸಹಾಯವಾಣಿ</div>
                    <div class="dept-name-en">Aranya Helpline</div>
                    <div class="dept-sub">Petition Management System — Vigilance Wing</div>
                </div>
            </div>
        </div>
    </header>

    <!-- Navigation -->
    <nav class="main-nav">
        <div class="container">
            <ul class="nav">
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")"
                       href="/Public/SubmitComplaint">
                        <i class="bi bi-pencil-square"></i>Submit Complaint
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Track" ? "active" : "")"
                       href="/Public/TrackStatus">
                        <i class="bi bi-search"></i>Track Status
                    </a>
                </li>
                @if (User.IsInRole("OfficeAssistant"))
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/OfficeAssistant/Dashboard">
                            <i class="bi bi-clipboard-check"></i>Dashboard
                        </a>
                    </li>
                }
                @if (User.IsInRole("APCCF"))
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/APCCF/Dashboard">
                            <i class="bi bi-speedometer2"></i>Dashboard
                        </a>
                    </li>
                }
                @if (User.IsInRole("CircleOfficer") || User.IsInRole("DivisionOfficer") || User.IsInRole("FMSOfficer"))
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/FieldOfficer/Dashboard">
                            <i class="bi bi-person-badge"></i>My Petitions
                        </a>
                    </li>
                }
            </ul>
        </div>
    </nav>

    <!-- Page Content -->
    <main class="page-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="main-footer">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>© @DateTime.Now.Year Karnataka Forest Department. All rights reserved.</span>
            <span>Vigilance Wing — APCCF (Vigilance)</span>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
